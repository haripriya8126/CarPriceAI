{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "CarPriceAI: Backend",
      "type": "shell",
      "command": "${workspaceFolder}/backend/venv/Scripts/python.exe",
      "windows": {
        "command": "${workspaceFolder}/backend/venv/Scripts/python.exe"
      },
      "linux": {
        "command": "${workspaceFolder}/backend/venv/bin/python"
      },
      "osx": {
        "command": "${workspaceFolder}/backend/venv/bin/python"
      },
      "args": ["app.py"],
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "CarPriceAI: Frontend",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "Start CarPriceAI",
      "dependsOn": ["CarPriceAI: Backend", "CarPriceAI: Frontend"],
      "dependsOrder": "parallel",
      "problemMatcher": []
    }
  ]
}
